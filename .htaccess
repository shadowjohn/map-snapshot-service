Options -Indexes
DirectoryIndex index.php index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule (^|/)\.git(/|$) - [R=404,L]
  RewriteRule (^|/)\.superpowers(/|$) - [R=404,L]
</IfModule>

<FilesMatch "^\.">
  Require all denied
</FilesMatch>

<IfModule !mod_authz_core.c>
  <FilesMatch "^\.">
    Order allow,deny
    Deny from all
  </FilesMatch>
</IfModule>
